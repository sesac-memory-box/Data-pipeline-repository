# Public data API
PUBLIC_API_BASE_URL=
PUBLIC_API_SERVICE_KEY=

# Backend server
BACKEND_BASE_URL=
BACKEND_DATA_ENDPOINT=/api/data

# Runtime
REQUEST_TIMEOUT_SECONDS=10

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=memory_box_root_password
MYSQL_USER=memory_box_user
MYSQL_PASSWORD=memory_box_password
MYSQL_DATABASE=memory_box
MYSQL_TABLE_RECORDS=historical_records

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=memory_box_records
QDRANT_VECTOR_SIZE=384

# Embedding
EMBEDDING_PROVIDER=hash
EMBEDDING_DIM=384
EMBEDDING_API_URL=

# Ingestion
INGESTION_BATCH_SIZE=500
