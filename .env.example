# Public data API
PUBLIC_API_BASE_URL=
PUBLIC_API_SERVICE_KEY=

# Backend server
BACKEND_BASE_URL=
BACKEND_DATA_ENDPOINT=/api/data

# Runtime
REQUEST_TIMEOUT_SECONDS=10

# MySQL
DB_HOST=
DB_PORT=3306
DB_NAME=memorybox
DB_USER=
DB_PASSWORD=
DB_CHARSET=utf8mb4
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=memory_box_root_password
MYSQL_USER=memory_box_user
MYSQL_PASSWORD=memory_box_password
MYSQL_DATABASE=memory_box
MYSQL_TABLE_RECORDS=historical_records

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION=memory_box_contents
QDRANT_DISTANCE=Cosine

# Embedding
FASTEMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Ingestion
BATCH_SIZE=64
INGESTION_BATCH_SIZE=64
CHUNK_SIZE=700
CHUNK_OVERLAP=100
RESET_COLLECTION=false
